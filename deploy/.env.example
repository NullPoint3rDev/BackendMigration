# PostgreSQL на хосте Windows (не в Docker)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
# На хосте PostgreSQL должен реально слушать этот порт (postgresql.conf → port).
POSTGRES_DB=weldtelecom
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-password-here

# Порты приложения на хосте
# Хост:контейнер — снаружи BACKEND_HTTP_PORT, внутри контейнера API всегда 8085 (nginx → backend:8085)
BACKEND_HTTP_PORT=8085
FRONTEND_HTTP_PORT=80
# TCP сварочных аппаратов (хост и процесс в контейнере — один и тот же порт)
WELDING_ARCHIVE_SERVER_PORT=3003

# JWT (замените на свой секрет ≥ 32 символов)
APP_JWT_SECRET=change-me-staging-jwt-secret-min-32-chars
APP_JWT_EXPIRATION_MS=43200000

# Путь к клону FrontendStaging (если папки лежат не рядом с BackendStaging)
# FRONTEND_BUILD_CONTEXT=../../FrontendStaging

# ── Мониторинг (Prometheus + Grafana + Loki) ──────────────────────────────
# Grafana доступна по LAN-адресу сервера: http://<ip-сервера>:GRAFANA_HTTP_PORT
GRAFANA_HTTP_PORT=3050
GRAFANA_ADMIN_USER=admin
# ОБЯЗАТЕЛЬНО замените на надёжный пароль
GRAFANA_ADMIN_PASSWORD=change-me-grafana-admin
# Срок хранения метрик Prometheus
PROMETHEUS_RETENTION=30d
# Management-порт Spring Boot Actuator (внутри docker-сети, наружу НЕ публикуется)
MANAGEMENT_SERVER_PORT=9100
