{
  "uid": "wt2-windows-host",
  "title": "WT2 — Windows-хост",
  "tags": ["wt2", "windows"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "windows_exporter", "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "mappings": [ { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } } ], "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "up{job=\"windows\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "Uptime хоста", "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "time() - windows_system_system_up_time", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "CPU (%)", "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null }, { "color": "orange", "value": 70 }, { "color": "red", "value": 90 } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "100 - (avg(rate(windows_cpu_time_total{mode=\"idle\"}[5m])) * 100)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "Мин. свободно на дисках (%)", "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "red", "value": null }, { "color": "orange", "value": 10 }, { "color": "green", "value": 20 } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "min(windows_logical_disk_free_bytes / windows_logical_disk_size_bytes * 100)", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "CPU по режимам (%)", "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "percent", "custom": { "drawStyle": "line", "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "avg by (mode) (rate(windows_cpu_time_total{mode!=\"idle\"}[5m])) * 100", "legendFormat": "{{mode}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Память (использовано / доступно)", "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "windows_cs_physical_memory_bytes - windows_memory_available_bytes", "legendFormat": "used", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "windows_memory_available_bytes", "legendFormat": "available", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Свободно на дисках (%)", "id": 12,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "windows_logical_disk_free_bytes / windows_logical_disk_size_bytes * 100", "legendFormat": "{{volume}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Диск I/O (байт/с)", "id": 13,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(windows_logical_disk_read_bytes_total[5m])", "legendFormat": "read {{volume}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rate(windows_logical_disk_write_bytes_total[5m])", "legendFormat": "write {{volume}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Сеть (байт/с)", "id": 14,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "Bps", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "rate(windows_net_bytes_received_total[5m])", "legendFormat": "rx {{nic}}", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "rate(windows_net_bytes_sent_total[5m])", "legendFormat": "tx {{nic}}", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Состояние службы PostgreSQL", "id": 15,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "windows_service_state{name=~\"postgresql.*\", state=\"running\"}", "legendFormat": "{{name}} running", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    }
  ]
}
