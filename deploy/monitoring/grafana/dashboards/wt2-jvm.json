{
  "uid": "wt2-jvm-micrometer",
  "title": "WT2 — JVM / Spring Boot",
  "tags": ["wt2", "jvm", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "stat", "title": "Uptime", "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "green", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "process_uptime_seconds{job=\"wt2-backend\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "Live threads", "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "jvm_threads_live_threads{job=\"wt2-backend\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "Loaded classes", "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "jvm_classes_loaded_classes{job=\"wt2-backend\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "stat", "title": "Open file descriptors", "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [ { "color": "blue", "value": null } ] } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "process_files_open_files{job=\"wt2-backend\"}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Память JVM по области (used)", "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (area) (jvm_memory_used_bytes{job=\"wt2-backend\"})", "legendFormat": "{{area}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "Heap used / committed / max", "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "bytes", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "sum(jvm_memory_used_bytes{job=\"wt2-backend\", area=\"heap\"})", "legendFormat": "used", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "sum(jvm_memory_committed_bytes{job=\"wt2-backend\", area=\"heap\"})", "legendFormat": "committed", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "expr": "sum(jvm_memory_max_bytes{job=\"wt2-backend\", area=\"heap\"} > 0)", "legendFormat": "max", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "GC: паузы (rate, с/с)", "id": 12,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (action, cause) (rate(jvm_gc_pause_seconds_sum{job=\"wt2-backend\"}[5m]))", "legendFormat": "{{action}} / {{cause}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "GC: события (в минуту)", "id": 13,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [ { "refId": "A", "expr": "sum by (action) (rate(jvm_gc_pause_seconds_count{job=\"wt2-backend\"}[5m])) * 60", "legendFormat": "{{action}}", "datasource": { "type": "prometheus", "uid": "prometheus" } } ]
    },
    {
      "type": "timeseries", "title": "CPU (process / system)", "id": 14,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "process_cpu_usage{job=\"wt2-backend\"}", "legendFormat": "process", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "system_cpu_usage{job=\"wt2-backend\"}", "legendFormat": "system", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries", "title": "Потоки (live / daemon)", "id": 15,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "jvm_threads_live_threads{job=\"wt2-backend\"}", "legendFormat": "live", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "expr": "jvm_threads_daemon_threads{job=\"wt2-backend\"}", "legendFormat": "daemon", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
